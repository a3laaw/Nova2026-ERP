rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف المساعدة الأساسية (Helpers) ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // جلب بيانات المستخدم من السجل العالمي (مصدر الحقيقة)
    function getGlobalUser() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    // التحقق من هوية المطور (الوصول المطلق للدعم الفني)
    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@novaflow.com' ||
        getGlobalUser().isDeveloper == true
      );
    }

    // التحقق من الانتماء للمنشأة (Tenant Isolation) - أهم قاعدة أمنية
    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        getGlobalUser().companyId == companyId
      );
    }

    // التحقق من صلاحيات المدير داخل المنشأة
    function isAdmin(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (getGlobalUser().companyId == companyId && 
         (getGlobalUser().role == 'admin' || getGlobalUser().roleCode == 'Admin'))
      );
    }

    // --- قواعد المجموعات (Collection Rules) ---

    // 1. السجل العالمي للمستخدمين
    match /global_users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isDeveloper());
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    // 2. نطاق الشركات (Tenants)
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow update: if isAdmin(companyId);
      allow create: if isAuthenticated();

      // أ) الأدوار والصلاحيات (تعديل المدير فقط)
      match /roles/{roleId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // ب) الموظفين (Tenant Users)
      match /users/{uid} {
        allow read: if belongsToCompany(companyId);
        allow create: if isAuthenticated() && request.auth.uid == uid;
        allow update, delete: if isAdmin(companyId);
      }

      // ج) المرجعيات (الدستور التشغيلي) - الكتابة للمدير فقط
      match /departments/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /governorates/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /activityTypes/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      
      // د) المشاريع والعمليات الإنشائية
      match /projects/{projectId} {
        allow read: if belongsToCompany(companyId);
        allow write: if belongsToCompany(companyId); // الإنفاذ الدقيق للصلاحيات يتم في الـ Service
        
        match /stageInstances/{instanceId} {
          allow read, write: if belongsToCompany(companyId);
        }
        match /contracts/{contractId} {
          allow read, write: if belongsToCompany(companyId);
        }
      }

      // هـ) الموارد البشرية (إجازات، رواتب، امتثال)
      match /leaves/{leaveId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if isAdmin(companyId) || (
          isAuthenticated() && 
          resource.data.userId == request.auth.uid && 
          resource.data.status == 'pending'
        );
        allow delete: if isAdmin(companyId);
      }
      
      match /payroll/{allPaths=**} {
        allow read, write: if isAdmin(companyId); // الرواتب حساسة جداً
      }

      // و) المشتريات والمخازن (CRM, Quotes, GRN, etc)
      match /leads/{leadId} { allow read, write: if belongsToCompany(companyId); }
      match /quotations/{allPaths=**} { allow read, write: if belongsToCompany(companyId); }
      match /purchaseRequests/{allPaths=**} { allow read, write: if belongsToCompany(companyId); }
      match /grns/{allPaths=**} { allow read, write: if belongsToCompany(companyId); }
      match /inventory/{allPaths=**} { allow read, write: if belongsToCompany(companyId); }

      // ز) المحاسبة والمالية (Journal, COA, Vouchers)
      match /accounting/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if belongsToCompany(companyId); // المحاسبون والمدراء
      }

      // ح) التنبيهات والإعدادات
      match /notifications/{notifId} {
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isDeveloper());
        allow write: if belongsToCompany(companyId);
      }
      
      match /settings/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
    }
  }
}