rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق مما إذا كان المستخدم هو المطور
    function isDeveloper() {
      return request.auth != null && 
             get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.isDeveloper == true;
    }

    // قواعد المستخدمين العالميين
    match /global_users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isDeveloper());
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // قواعد طلبات الانضمام - السماح للعامة بالإنشاء وللمطور بالإدارة
    match /company_requests/{requestId} {
      allow create: if true; 
      allow read, update, delete: if isDeveloper();
    }
    
    // قواعد الشركات
    match /companies/{companyId} {
      // المطور فقط يمكنه إنشاء الشركة (عند التفعيل)
      allow create: if isDeveloper();
      
      // القراءة للمنتمين للشركة أو المطور
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId ||
        isDeveloper()
      );
      
      // قواعد البيانات الداخلية للشركة
      match /{allPaths=**} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId ||
          isDeveloper()
        );
      }
    }
  }
}