rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- الدوال المساعدة (Helper Functions) ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getGlobalUser() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@novaflow.com' ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getGlobalUser().isDeveloper == true)
      );
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getGlobalUser().companyId == companyId)
      );
    }

    function isAdmin(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getGlobalUser().companyId == companyId && 
         (getGlobalUser().role == 'admin' || getGlobalUser().roleCode == 'Admin'))
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- السجلات العالمية ---
    
    match /global_users/{uid} {
      // السماح للقراءة إذا كان المالك أو مطور أو مدير لنفس الشركة
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isDeveloper() || 
        (exists(/databases/$(database)/documents/global_users/$(uid)) && 
         isAdmin(get(/databases/$(database)/documents/global_users/$(uid)).data.companyId))
      );
      
      // السماح بالكتابة إذا كان المالك أو مطور أو مدير لنفس الشركة (لتحديث الأدوار)
      allow write: if isDeveloper() || (isAuthenticated() && (
        request.auth.uid == uid ||
        (exists(/databases/$(database)/documents/global_users/$(uid)) && 
         isAdmin(get(/databases/$(database)/documents/global_users/$(uid)).data.companyId))
      ));
    }
    
    match /company_requests/{reqId} {
       allow create: if true;
       allow read, write: if isDeveloper();
    }

    // --- سجلات المنشأة (Multi-tenant) ---
    
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow update: if isAdmin(companyId);
      allow create: if isAuthenticated();

      // الموظفين وسجلات التدقيق
      match /employees/{employeeId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
        
        match /auditLogs/{logId} {
          allow read: if belongsToCompany(companyId);
          allow create: if isAdmin(companyId);
          allow update, delete: if false; 
        }
      }

      // المشتريات والتوريد
      match /suppliers/{supId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
      match /purchaseOrders/{poId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // طلبات الإجازات (Leave Requests)
      match /leaveRequests/{leaveId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId);
        allow delete: if isAdmin(companyId);
      }

      // طلبات الاستئذان (Permission Requests)
      match /permissionRequests/{requestId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId);
        allow delete: if isAdmin(companyId);
      }

      // سجلات الحضور (Attendance)
      match /attendance/{attId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // الرواتب (Payroll)
      match /payroll/{batchId} {
        allow read: if belongsToCompany(companyId) && isAdmin(companyId);
        allow write: if isAdmin(companyId);

        match /records/{recordId} {
          allow read: if belongsToCompany(companyId);
          allow write: if isAdmin(companyId);
        }
      }

      // المسارات الفنية والخدمات
      match /activityTypes/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /departments/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /governorates/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /roles/{roleId} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      
      // المشاريع والعملاء
      match /leads/{leadId} { allow read, write: if belongsToCompany(companyId); }
      match /projects/{allPaths=**} { allow read, write: if belongsToCompany(companyId); }
      
      // الإعدادات العامة
      match /settings/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
      match /holidays/{allPaths=**} { allow read: if belongsToCompany(companyId); allow write: if isAdmin(companyId); }
    }
  }
}