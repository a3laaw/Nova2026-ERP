
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- الدوال المساعدة المطورة ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@novaflow.com' ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().isDeveloper == true)
      );
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().companyId == companyId)
      );
    }

    function isAdmin(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().companyId == companyId && 
         (getUserData().role == 'admin' || getUserData().role == 'Admin' || getUserData().roleCode == 'ADMIN'))
      );
    }

    // --- السجلات العالمية ---
    
    match /global_users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isDeveloper() || isAdmin(get(/databases/$(database)/documents/global_users/$(uid)).data.companyId));
      allow create, update: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid) || (isAuthenticated() && isAdmin(request.resource.data.companyId));
      allow delete: if isDeveloper();
    }
    
    match /company_requests/{reqId} {
       allow create: if true;
       allow read, write: if isDeveloper();
    }

    // --- سجلات المنشأة (Multi-tenant) ---
    
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      
      // 1. قواعد مخصصة للطلبات التشغيلية (يسمح للموظف بالإرسال)
      match /leaveRequests/{id} {
        allow create: if belongsToCompany(companyId);
        allow read: if belongsToCompany(companyId);
        allow update, delete: if isAdmin(companyId);
      }

      match /permissionRequests/{id} {
        allow create: if belongsToCompany(companyId);
        allow read: if belongsToCompany(companyId);
        allow update, delete: if isAdmin(companyId);
      }

      match /leads/{id} {
        allow create, update: if belongsToCompany(companyId);
        allow read: if belongsToCompany(companyId);
        allow delete: if isAdmin(companyId);
      }

      match /attendance/{id} {
        allow read: if belongsToCompany(companyId);
        allow create, update: if isAdmin(companyId);
      }

      // 2. الوصول العام للمدير على كافة المجموعات الأخرى
      match /{allSubCollections=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
    }
  }
}
