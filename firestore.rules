rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // السماح للمستخدم بإنشاء وقراءة ملفه العالمي
    match /global_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // السماح بإنشاء شركة جديدة لأي مستخدم مسجل، والقراءة للمنتمين لها
    match /companies/{companyId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId;
      
      // قواعد المستخدمين داخل الشركة
      match /users/{uid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      
      // قواعد الأقسام الأخرى (المشاريع، المحاسبة، إلخ)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && 
          get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId;
      }
    }
  }
}