rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق مما إذا كان المستخدم هو المطور
    function isDeveloper() {
      return request.auth != null && (
        get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.isDeveloper == true ||
        request.auth.token.email == 'admin@novaflow.com'
      );
    }

    // قواعد المستخدمين العالميين
    match /global_users/{uid} {
      // السماح بإنشاء السجل للمستخدم نفسه أثناء التسجيل
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && (request.auth.uid == uid || isDeveloper());
      allow update, delete: if request.auth != null && (request.auth.uid == uid || isDeveloper());
    }
    
    // قواعد طلبات الانضمام
    match /company_requests/{requestId} {
      allow create: if true; 
      allow read, update, delete: if isDeveloper();
    }
    
    // قواعد الشركات
    match /companies/{companyId} {
      // السماح بإنشاء شركة جديدة لأي مستخدم مسجل (التفعيل الذاتي)
      allow create: if request.auth != null;
      
      // القراءة للمنتمين للشركة أو المطور
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId ||
        isDeveloper()
      );

      // السماح بالتحديث للمطور أو لمالك الشركة (يمكن إضافة منطق المالك لاحقاً)
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId ||
        isDeveloper()
      );
      
      // قواعد البيانات الداخلية للشركة (المستندات الفرعية)
      match /{allPaths=**} {
        // السماح بإنشاء أول مستخدم (Admin) داخل الشركة أثناء التسجيل
        // نستخدم التحقق من الـ UID مباشرة لأن الـ get() للمستخدم العالمي قد لا يكون متاحاً فوراً في نفس الـ batch
        allow create: if request.auth != null; 
        
        // باقي العمليات تتطلب الانتماء للشركة
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.companyId == companyId ||
          isDeveloper()
        );
      }
    }
  }
}