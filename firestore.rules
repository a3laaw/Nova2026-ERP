
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- الدوال المساعدة المطورة ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@novaflow.com' ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().isDeveloper == true)
      );
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().companyId == companyId)
      );
    }

    function isAdmin(companyId) {
      return isAuthenticated() && (
        isDeveloper() ||
        (exists(/databases/$(database)/documents/global_users/$(request.auth.uid)) && 
         getUserData().companyId == companyId && 
         (getUserData().role in ['admin', 'Admin'] || getUserData().roleCode == 'Admin'))
      );
    }

    // --- السجلات العالمية ---
    
    match /global_users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isDeveloper());
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    match /company_requests/{reqId} {
       allow create: if true;
       allow read, write: if isDeveloper();
    }

    // --- سجلات المنشأة (Multi-tenant) ---
    
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow write: if isAdmin(companyId);

      // السماح بالوصول الكامل للأدمن على كافة المجموعات الفرعية
      match /{allSubCollections=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
      
      // قواعد إضافية للخدمة الذاتية (الموظفين) لضمان العمليات الأساسية
      match /leaveRequests/{leaveId} {
        allow create, update: if belongsToCompany(companyId);
      }
      match /permissionRequests/{requestId} {
        allow create, update: if belongsToCompany(companyId);
      }
    }
  }
}
