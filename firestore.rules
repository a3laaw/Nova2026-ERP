rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف المساعدة الأساسية (Helpers) ---

    // التحقق من تسجيل الدخول
    function isAuthenticated() {
      return request.auth != null;
    }

    // جلب بيانات المستخدم العالمي
    function getGlobalUser() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    // التحقق مما إذا كان المستخدم مطوراً للنظام (Global Developer)
    function isDeveloper() {
      return isAuthenticated() && (
        getGlobalUser().isDeveloper == true ||
        request.auth.token.email == 'admin@novaflow.com'
      );
    }

    // التحقق من الانتماء للشركة (Tenant Isolation)
    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        getGlobalUser().companyId == companyId ||
        isDeveloper()
      );
    }

    // التحقق من دور المدير (Admin) داخل الشركة
    function isAdmin(companyId) {
      return isAuthenticated() && (
        (getGlobalUser().companyId == companyId && getGlobalUser().role == 'admin') ||
        isDeveloper()
      );
    }

    // --- قواعد المجموعات (Collection Rules) ---

    // 1. حسابات المستخدمين العالميين
    match /global_users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isDeveloper());
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    // 2. هيكل الشركات والبيانات الموزعة (Multi-tenant)
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow update: if isAdmin(companyId);
      allow create: if isAuthenticated();

      // الإعدادات (Settings & Roles)
      match /settings/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      match /roles/{roleId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // الموظفين
      match /users/{uid} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // المرجعيات
      match /activityTypes/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // العمليات
      match /projects/{allPaths=**} {
        allow read, write: if belongsToCompany(companyId);
      }
      
      match /leads/{allPaths=**} {
        allow read, write: if belongsToCompany(companyId);
      }
    }
  }
}
