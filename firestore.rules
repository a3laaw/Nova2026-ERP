rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- وظائف المساعدة الأساسية (Helpers) ---

    // التحقق من تسجيل الدخول
    function isAuthenticated() {
      return request.auth != null;
    }

    // جلب بيانات المستخدم العالمي
    function getGlobalUser() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data;
    }

    // التحقق مما إذا كان المستخدم مطوراً للنظام (Global Developer)
    function isDeveloper() {
      return isAuthenticated() && (
        getGlobalUser().isDeveloper == true ||
        request.auth.token.email == 'admin@novaflow.com'
      );
    }

    // التحقق من الانتماء للشركة (Tenant Isolation)
    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        getGlobalUser().companyId == companyId ||
        isDeveloper()
      );
    }

    // التحقق من دور المدير (Admin) داخل الشركة
    function isAdmin(companyId) {
      return isAuthenticated() && (
        (getGlobalUser().companyId == companyId && getGlobalUser().role == 'admin') ||
        isDeveloper()
      );
    }

    // --- قواعد المجموعات (Collection Rules) ---

    // 1. حسابات المستخدمين العالميين
    match /global_users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isDeveloper());
      allow write: if isDeveloper() || (isAuthenticated() && request.auth.uid == uid);
    }
    
    // 2. طلبات الانضمام
    match /company_requests/{requestId} {
      allow create: if true; 
      allow read, write: if isDeveloper();
    }
    
    // 3. هيكل الشركات والبيانات الموزعة (Multi-tenant)
    match /companies/{companyId} {
      // قراءة بيانات الشركة الأساسية
      allow read: if belongsToCompany(companyId);
      // تحديث بيانات الشركة للمدير أو المطور
      allow update: if isAdmin(companyId);
      // الإنشاء محصور في منطق التسجيل والمطور
      allow create: if isAuthenticated();

      // --- الإعدادات (Settings) ---
      match /settings/{settingId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // --- المرجعيات والقواعد (Reference Data) ---
      
      // الأقسام والوظائف
      match /departments/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
      
      // الجغرافيا (المحافظات والمناطق)
      match /governorates/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }
      
      // الهيكل المرجعي الفني الجديد (Activity Types -> Services -> Sub-Services -> Technical Stages)
      match /activityTypes/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdmin(companyId);
      }

      // --- البيانات التشغيلية (Operational Data) ---
      
      // المشاريع والعقود والمراحل التنفيذية
      match /projects/{projectId} {
        allow read, write: if belongsToCompany(companyId);
        
        // مراحل المشروع (Instances)
        match /stageInstances/{instanceId} {
          allow read, write: if belongsToCompany(companyId);
        }
        
        // العقود (Contracts)
        match /contracts/{contractId} {
          allow read: if belongsToCompany(companyId);
          allow write: if isAdmin(companyId);
        }
      }

      // العملاء المحتملين (CRM)
      match /leads/{leadId} {
        allow read, write: if belongsToCompany(companyId);
      }

      // المعاملات المالية (Transactions) والجدول الزمني (Timeline)
      match /transactions/{txId} {
        allow read, write: if belongsToCompany(companyId);
      }
      
      match /timelineEvents/{eventId} {
        allow read, write: if belongsToCompany(companyId);
      }
    }
  }
}