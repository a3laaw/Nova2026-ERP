
{
  "entities": {
    "GlobalUser": {
      "title": "Global User Mapping",
      "description": "يربط المعرف الفريد للمستخدم بالشركة التي ينتمي إليها ويحدد دوره العالمي.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "developer"] },
        "isDeveloper": { "type": "boolean" },
        "username": { "type": "string" }
      },
      "required": ["companyId", "role", "username"]
    },
    "Company": {
      "title": "Company Profile",
      "description": "بيانات الشركة الأساسية وقيود الاشتراك.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "trialEndsAt": { "type": "string", "format": "date-time" },
        "maxUsers": { "type": "number" }
      },
      "required": ["name", "status"]
    },
    "Contract": {
      "title": "Project Contract",
      "description": "بيانات العقد المالي المرتبط بمشروع.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed", "terminated"] },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "amount": { "type": "number" },
              "percentage": { "type": "number" },
              "status": { "type": "string", "enum": ["pending", "due", "paid"] },
              "linkedStageId": { "type": "string" },
              "linkedMilestoneKey": { "type": "string" }
            }
          }
        }
      }
    },
    "StageInstance": {
      "title": "Stage Execution Instance",
      "description": "نسخة تشغيلية من المرحلة الفنية مرتبطة بمشروع فعلي.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "stageId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "skipped"] },
        "billableTrigger": { "type": "boolean" },
        "milestoneKey": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "completedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/global_users/{uid}": { "schema": "#/entities/GlobalUser", "description": "تخزين المسار الأساسي للمستخدم" },
    "/companies/{companyId}": { "schema": "#/entities/Company", "description": "بيانات الشركة" },
    "/companies/{companyId}/projects/{projectId}/contracts/{contractId}": { "schema": "#/entities/Contract", "description": "عقود المشاريع" },
    "/companies/{companyId}/projects/{projectId}/stages/{instanceId}": { "schema": "#/entities/StageInstance", "description": "تنفيذ مراحل المشروع" }
  }
}
