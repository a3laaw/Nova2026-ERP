
{
  "entities": {
    "Client": {
      "title": "Client Record",
      "description": "الجذر التجاري للعميل في النظام، يحتوي على بيانات التواصل والعنوان والحالة التشغيلية.",
      "type": "object",
      "properties": {
        "fileNumber": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["fileNumber", "nameAr", "mobile", "status", "companyId"]
    },
    "Transaction": {
      "title": "Technical Transaction",
      "description": "المعاملة الفنية المفتوحة للعميل، ترتبط بمسار فني محدد.",
      "type": "object",
      "properties": {
        "transactionNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "activityTypeId": { "type": "string" },
        "serviceId": { "type": "string" },
        "subServiceId": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "in-progress", "completed", "on-hold", "cancelled"] },
        "companyId": { "type": "string" }
      },
      "required": ["transactionNumber", "clientId", "activityTypeId", "serviceId", "subServiceId", "status", "companyId"]
    },
    "Supplier": {
      "title": "Supplier Record",
      "description": "بيانات المورد المعتمد في نظام المشتريات.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "rating": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "category", "companyId"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order (PO)",
      "description": "أمر شراء صادر لمورد لمواد أو خدمات ميدانية.",
      "type": "object",
      "properties": {
        "poNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending", "approved", "shipped", "received", "cancelled"] },
        "companyId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/clients/{clientId}": { "schema": "#/entities/Client", "description": "سجلات العملاء" },
    "/companies/{companyId}/transactions/{tId}": { "schema": "#/entities/Transaction", "description": "المعاملات الفنية" },
    "/companies/{companyId}/suppliers/{supId}": { "schema": "#/entities/Supplier", "description": "بيانات الموردين" },
    "/companies/{companyId}/purchaseOrders/{poId}": { "schema": "#/entities/PurchaseOrder", "description": "أوامر الشراء" }
  }
}
