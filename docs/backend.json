
{
  "entities": {
    "GlobalUser": {
      "title": "Global User Mapping",
      "description": "يربط المعرف الفريد للمستخدم بالشركة التي ينتمي إليها ويحدد دوره العالمي.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "developer"] },
        "isDeveloper": { "type": "boolean" },
        "username": { "type": "string" }
      },
      "required": ["companyId", "role", "username"]
    },
    "Company": {
      "title": "Company Profile",
      "description": "بيانات الشركة الأساسية وقيود الاشتراك.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "trialEndsAt": { "type": "string", "format": "date-time" },
        "maxUsers": { "type": "number" }
      },
      "required": ["name", "status"]
    },
    "Department": {
      "title": "Department",
      "description": "الأقسام الإدارية والفنية (معماري، إنشائي، إلخ).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Job": {
      "title": "Job Title",
      "description": "المسميات الوظيفية التابعة للأقسام.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "departmentId": { "type": "string" }
      }
    },
    "ServiceType": {
      "title": "Service Category",
      "description": "أنشطة الأعمال الكبرى (استشارات، مقاولات).",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "TransactionType": {
      "title": "Transaction Type",
      "description": "أنواع المعاملات والمسارات الفنية (تصميم بلدية، عقد ترميم).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "serviceTypeId": { "type": "string" },
        "departmentIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SubService": {
      "title": "Sub Service",
      "description": "الخدمات التفصيلية التابعة لنوع المعاملة.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": "string" }
      }
    },
    "TechnicalStage": {
      "title": "WBS / Technical Stage",
      "description": "مراحل العمل التفصيلية (WBS) للمسار الفني.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "controlType": { "type": "string", "enum": ["TimeBased", "Numeric", "Hybrid"] },
        "controlValue": { "type": "object" },
        "nextStageIds": { "type": "array", "items": { "type": "string" } },
        "isEditable": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/global_users/{uid}": { "schema": "#/entities/GlobalUser", "description": "تخزين المسار الأساسي للمستخدم" },
    "/companies/{companyId}": { "schema": "#/entities/Company", "description": "بيانات الشركة" },
    "/companies/{companyId}/departments/{id}": { "schema": "#/entities/Department", "description": "الأقسام" },
    "/companies/{companyId}/serviceTypes/{id}": { "schema": "#/entities/ServiceType", "description": "أنشطة الأعمال" },
    "/companies/{companyId}/transactionTypes/{id}": { "schema": "#/entities/TransactionType", "description": "أنواع المسارات الفنية" },
    "/companies/{companyId}/transactionTypes/{txId}/subServices/{subId}": { "schema": "#/entities/SubService", "description": "الخدمات الفرعية" },
    "/companies/{companyId}/transactionTypes/{txId}/subServices/{subId}/technicalStages/{stageId}": { "schema": "#/entities/TechnicalStage", "description": "مراحل WBS" }
  }
}
