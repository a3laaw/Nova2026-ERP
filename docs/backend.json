
{
  "entities": {
    "Client": {
      "title": "Client Record",
      "description": "الجذر التجاري للعميل في النظام، يحتوي على بيانات التواصل والعنوان والحالة التشغيلية.",
      "type": "object",
      "properties": {
        "fileNumber": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["fileNumber", "nameAr", "mobile", "status", "companyId"]
    },
    "Employee": {
      "title": "Employee Record",
      "description": "سجل الموظف الشامل والبيانات المالية والوظيفية.",
      "type": "object",
      "properties": {
        "employeeNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "civilId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "basicSalary": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Technical Transaction",
      "description": "المعاملة الفنية المفتوحة للعميل، ترتبط بمسار فني محدد.",
      "type": "object",
      "properties": {
        "transactionNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "activityTypeId": { "type": "string" },
        "serviceId": { "type": "string" },
        "subServiceId": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "in-progress", "completed", "on-hold", "cancelled"] },
        "companyId": { "type": "string" }
      },
      "required": ["transactionNumber", "clientId", "activityTypeId", "serviceId", "subServiceId", "status", "companyId"]
    },
    "Supplier": {
      "title": "Supplier Record",
      "description": "بيانات المورد المعتمد في نظام المشتريات.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "rating": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "category", "companyId"]
    },
    "Warehouse": {
      "title": "Warehouse Location",
      "description": "بيانات المخزن أو الموقع التخزيني التابع للشركة.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "managerId": { "type": "string" },
        "companyId": { "type": "string" }
      }
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "الأصناف المخزنية والمواد المتاحة في المستودعات.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "warehouseId": { "type": "string" },
        "companyId": { "type": "string" }
      }
    },
    "AssetAssignment": {
      "title": "Field Asset Assignment",
      "description": "سجل تسليم العهد الميدانية والمعدات للموظفين والمهندسين.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["in-use", "returned", "damaged", "lost"] },
        "companyId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/clients/{clientId}": { "schema": "#/entities/Client", "description": "سجلات العملاء" },
    "/companies/{companyId}/employees/{empId}": { "schema": "#/entities/Employee", "description": "سجلات الموظفين" },
    "/companies/{companyId}/transactions/{tId}": { "schema": "#/entities/Transaction", "description": "المعاملات الفنية" },
    "/companies/{companyId}/suppliers/{supId}": { "schema": "#/entities/Supplier", "description": "بيانات الموردين" },
    "/companies/{companyId}/warehouses/{wId}": { "schema": "#/entities/Warehouse", "description": "المستودعات" },
    "/companies/{companyId}/inventoryItems/{itemId}": { "schema": "#/entities/InventoryItem", "description": "الأصناف والمخزون" },
    "/companies/{companyId}/assetAssignments/{assignId}": { "schema": "#/entities/AssetAssignment", "description": "العهد الميدانية" }
  }
}
