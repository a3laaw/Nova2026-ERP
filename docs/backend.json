{
  "entities": {
    "Employee": {
      "title": "Employee Record",
      "description": "بيانات الموظف الشاملة لأغراض الموارد البشرية والرواتب.",
      "type": "object",
      "properties": {
        "employeeNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "civilId": { "type": "string" },
        "basicSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "on-leave", "terminated"] },
        "companyId": { "type": "string" }
      },
      "required": ["employeeNumber", "fullName", "civilId", "basicSalary"]
    },
    "AttendanceRecord": {
      "title": "Attendance",
      "description": "سجلات الحضور والانصراف اليومية.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "weekend", "holiday"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/employees/{empId}": { "schema": "#/entities/Employee", "description": "سجلات الموظفين" },
    "/companies/{companyId}/attendance/{attId}": { "schema": "#/entities/AttendanceRecord", "description": "سجلات الحضور" },
    "/companies/{companyId}/payroll/{payId}": { "description": "سجلات الرواتب الشهرية" },
    "/companies/{companyId}/leaveRequests/{leaveId}": { "description": "طلبات الإجازات المطورة" }
  }
}
