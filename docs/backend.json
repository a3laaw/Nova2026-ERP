
{
  "entities": {
    "Client": {
      "title": "Client Record",
      "description": "الجذر التجاري للعميل في النظام، يحتوي على بيانات التواصل والعنوان والحالة التشغيلية.",
      "type": "object",
      "properties": {
        "fileNumber": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["fileNumber", "nameAr", "mobile", "status", "companyId"]
    },
    "Employee": {
      "title": "Employee Record",
      "description": "سجل الموظف الشامل والبيانات المالية والوظيفية.",
      "type": "object",
      "properties": {
        "employeeNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "civilId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "basicSalary": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "PayrollBatch": {
      "title": "Payroll Batch",
      "description": "كشف رواتب شهري مجمع للموظفين.",
      "type": "object",
      "properties": {
        "month": { "type": "number" },
        "year": { "type": "number" },
        "status": { "type": "string" },
        "totalNetSalary": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "طلب إجازة مقدم من موظف.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string" },
        "companyId": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Technical Transaction",
      "description": "المعاملة الفنية المفتوحة للعميل، ترتبط بمسار فني محدد.",
      "type": "object",
      "properties": {
        "transactionNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "activityTypeId": { "type": "string" },
        "serviceId": { "type": "string" },
        "subServiceId": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "in-progress", "completed", "on-hold", "cancelled"] },
        "companyId": { "type": "string" }
      },
      "required": ["transactionNumber", "clientId", "activityTypeId", "serviceId", "subServiceId", "status", "companyId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/clients/{clientId}": { "schema": "#/entities/Client", "description": "سجلات العملاء" },
    "/companies/{companyId}/employees/{empId}": { "schema": "#/entities/Employee", "description": "سجلات الموظفين" },
    "/companies/{companyId}/payroll/{batchId}": { "schema": "#/entities/PayrollBatch", "description": "كشوف الرواتب" },
    "/companies/{companyId}/leaveRequests/{leaveId}": { "schema": "#/entities/LeaveRequest", "description": "طلبات الإجازات" },
    "/companies/{companyId}/transactions/{tId}": { "schema": "#/entities/Transaction", "description": "المعاملات الفنية" }
  }
}
