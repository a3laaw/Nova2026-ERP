
{
  "entities": {
    "Client": {
      "title": "Client Record",
      "description": "الجذر التجاري للعميل في النظام، يحتوي على بيانات التواصل والعنوان والحالة التشغيلية.",
      "type": "object",
      "properties": {
        "fileNumber": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "mobile": { "type": "string" },
        "status": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["fileNumber", "nameAr", "mobile", "status", "companyId"]
    },
    "Employee": {
      "title": "Employee Record",
      "description": "سجل الموظف الشامل والبيانات المالية والوظيفية.",
      "type": "object",
      "properties": {
        "employeeNumber": { "type": "string" },
        "fullName": { "type": "string" },
        "civilId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "basicSalary": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "JobApplication": {
      "title": "Job Application",
      "description": "طلب توظيف مقدم من مرشح خارجي عبر بوابة التوظيف العامة.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "position": { "type": "string" },
        "experienceYears": { "type": "number" },
        "resumeUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "reviewing", "interview", "rejected", "hired"] },
        "companyId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/companies/{companyId}/clients/{clientId}": { "schema": "#/entities/Client", "description": "سجلات العملاء" },
    "/companies/{companyId}/employees/{empId}": { "schema": "#/entities/Employee", "description": "سجلات الموظفين" },
    "/companies/{companyId}/applications/{appId}": { "schema": "#/entities/JobApplication", "description": "طلبات التوظيف المستلمة" }
  }
}
