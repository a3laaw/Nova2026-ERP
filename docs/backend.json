
{
  "entities": {
    "GlobalUser": {
      "title": "Global User Mapping",
      "description": "يربط المعرف الفريد للمستخدم بالشركة التي ينتمي إليها ويحدد دوره العالمي.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "developer"] },
        "isDeveloper": { "type": "boolean" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["companyId", "role", "username"]
    },
    "TenantUser": {
      "title": "Company Employee",
      "description": "بيانات الموظف التفصيلية داخل نطاق الشركة (Tenant).",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "departmentId": { "type": "string" },
        "jobTitleId": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["displayName", "email", "role"]
    },
    "Company": {
      "title": "Company Profile",
      "description": "بيانات الشركة الأساسية وقيود الاشتراك.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "trialEndsAt": { "type": "string", "format": "date-time" },
        "maxUsers": { "type": "number" },
        "logoUrl": { "type": "string", "description": "Base64 encoded logo image" },
        "headerImageUrl": { "type": "string", "description": "Base64 encoded header image" },
        "footerImageUrl": { "type": "string", "description": "Base64 encoded footer image" },
        "headerText": { "type": "string" },
        "footerText": { "type": "string" },
        "licenseExpiryDate": { "type": "string", "format": "date" },
        "laborAuthorityExpiryDate": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "commercialRegistry": { "type": "string" }
      },
      "required": ["name", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/global_users/{uid}": { "schema": "#/entities/GlobalUser", "description": "تخزين المسار الأساسي للمستخدم" },
    "/companies/{companyId}": { "schema": "#/entities/Company", "description": "بيانات الشركة" },
    "/companies/{companyId}/users/{uid}": { "schema": "#/entities/TenantUser", "description": "بيانات موظفي الشركة" }
  }
}
